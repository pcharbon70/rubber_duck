# Development Environment Variables Example
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL=ecto://postgres:postgres@localhost/rubber_duck_dev
POOL_SIZE=10
DB_CONNECT_TIMEOUT=15000
DB_HANDSHAKE_TIMEOUT=15000
DB_QUEUE_TARGET=5000
DB_QUEUE_INTERVAL=10000

# Web Configuration
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=development_secret_key_base_at_least_64_characters_long_for_security

# Application Configuration
MAX_CONVERSATION_MESSAGES=1000
CONVERSATION_RETENTION_DAYS=90
CACHE_TTL_HOURS=1
CACHE_MAX_SIZE=10000
ENGINE_POOL_SIZE=20
MAX_CONCURRENT_ANALYSES=10

# Optional: Monitoring and Error Tracking
# APPSIGNAL_PUSH_API_KEY=your_appsignal_key
# SENTRY_DSN=your_sentry_dsn
# HOSTNAME=rubber-duck-dev

# Optional: Clustering
# RELEASE_NODE=rubber_duck@127.0.0.1
# CLUSTER_NAME=rubber_duck_dev